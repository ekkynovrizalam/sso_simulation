# Mock server — generate strong values before shared lab deploy (see LAB_SECURITY.md)
MOCK_SERVER_PORT=8080
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_TTL=3600
ADMIN_KEY=change-me-use-openssl-rand-hex-24

# RabbitMQ — change defaults on shared lab servers (see LAB_SECURITY.md)
RABBITMQ_USER=iae_lab
RABBITMQ_PASS=change-me-strong-password
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Resource limits (Docker Compose deploy.resources)
MOCK_CPU_LIMIT=0.50
MOCK_MEM_LIMIT=128M
MOCK_CPU_RESERVE=0.10
MOCK_MEM_RESERVE=64M
RABBITMQ_CPU_LIMIT=1.00
RABBITMQ_MEM_LIMIT=512M
RABBITMQ_CPU_RESERVE=0.25
RABBITMQ_MEM_RESERVE=256M
